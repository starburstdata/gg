<idea-plugin>
    <id>com.jjuicy.intellij</id>
    <name>jjuicy</name>
    <vendor>jjuicy</vendor>
    <description><![CDATA[
        Native Jujutsu VCS GUI embedded as a sidebar tool window.
        Requires the <code>jjuicy</code> (or <code>gg</code>) binary to be available on PATH,
        or configured in Settings → Tools → jjuicy.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="jjuicy"
            anchor="right"
            secondary="false"
            factoryClass="com.jjuicy.intellij.GGToolWindowFactory"
            icon="/icons/gg-icon.svg"/>

        <projectService
            serviceImplementation="com.jjuicy.intellij.GGProcessManager"/>

        <projectService
            serviceImplementation="com.jjuicy.intellij.data.GGRepository"/>

        <applicationService
            serviceImplementation="com.jjuicy.intellij.GGSettings"/>

        <applicationConfigurable
            parentId="tools"
            instance="com.jjuicy.intellij.GGSettingsConfigurable"
            id="com.jjuicy.intellij.GGSettingsConfigurable"
            displayName="jjuicy"/>

        <notificationGroup
            id="jjuicy"
            displayType="BALLOON"/>

        <postStartupActivity
            implementation="com.jjuicy.intellij.GGStartupActivity"/>
    </extensions>

    <actions>
        <group id="GG.Toolbar" text="jjuicy Toolbar" popup="false">
            <action id="GG.Refresh"
                    class="com.jjuicy.intellij.actions.GGRefreshAction"
                    text="Refresh"
                    description="Reload the commit log"/>
            <action id="GG.Undo"
                    class="com.jjuicy.intellij.actions.GGUndoAction"
                    text="Undo"
                    description="Undo the last jj operation"/>
            <separator/>
            <action id="GG.Push"
                    class="com.jjuicy.intellij.actions.GGPushAction"
                    text="Push"
                    description="Push bookmarks to remote"/>
            <action id="GG.Fetch"
                    class="com.jjuicy.intellij.actions.GGFetchAction"
                    text="Fetch"
                    description="Fetch from remote"/>
        </group>
    </actions>
</idea-plugin>
